# =============================================================================
# Enterprise RAG Platform — Environment Variables
# Copy this file to .env and fill in your actual values.
# =============================================================================

# -----------------------------------------------------------------------------
# Groq — LLM inference for fast generation (chat, tool calls, agent reasoning)
# Get your API key at https://console.groq.com/
# -----------------------------------------------------------------------------
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Qdrant — Vector database for embeddings and semantic search
# URL: your Qdrant instance (local or cloud). API key required for Qdrant Cloud.
# -----------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# -----------------------------------------------------------------------------
# Neon — Serverless PostgreSQL for document metadata, users, and collections
# Connection string format: postgresql://user:password@host/dbname?sslmode=require
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@ep-xxx-xxx.region.aws.neon.tech/dbname?sslmode=require

# -----------------------------------------------------------------------------
# Upstash Redis — Caching for embeddings, responses, and session data
# URL and token from your Upstash Redis instance at https://upstash.com/
# -----------------------------------------------------------------------------
REDIS_URL=rediss://default:xxxxx@xxxxx.upstash.io:6379
REDIS_TOKEN=

# -----------------------------------------------------------------------------
# Langfuse — Observability, tracing, and evaluation for LLM and RAG pipelines
# Public key: safe to expose in frontend. Secret key: server-side only.
# -----------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Hugging Face — Token for embedding models and private model access
# Required for sentence-transformers and other HF-hosted models.
# Get your token at https://huggingface.co/settings/tokens
-----------------------------------------------------------------------------
HUGGINGFACE_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Google Gemini — Multimodal embedding API
# Get your API key at https://aistudio.google.com/
# -----------------------------------------------------------------------------
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview
GEMINI_EMBEDDING_DIMENSIONS=768

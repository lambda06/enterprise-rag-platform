# =============================================================================
# Enterprise RAG Platform — Environment Variables
# Copy this file to .env and fill in your actual values.
# Variables marked [REQUIRED] must be set. [OPTIONAL] have safe code defaults.
# =============================================================================

# -----------------------------------------------------------------------------
# Google Gemini — Primary LLM + embeddings (multimodal)
# Get your API key at https://aistudio.google.com/
# [REQUIRED] GEMINI_API_KEY — without this the entire RAG generation path fails.
# -----------------------------------------------------------------------------
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [OPTIONAL] Embedding model — default: gemini-embedding-2-preview
GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview

# [OPTIONAL] Embedding output dimensions (MRL sub-vector) — default: 768
# Must match QDRANT_VECTOR_SIZE. Change both together when rebuilding the index.
GEMINI_EMBEDDING_DIMENSIONS=768

# [OPTIONAL] Generation model — default: gemini-3.1-flash-lite-preview
# Other options: gemini-2.0-flash, gemini-2.5-flash
GEMINI_GENERATION_MODEL=gemini-3.1-flash-lite-preview

# -----------------------------------------------------------------------------
# Groq — Fast inference for the router node + RAGAS evaluation LLM (fallback)
# Get your API key at https://console.groq.com/
# [REQUIRED] GROQ_API_KEY — router node and RAGAS evaluator both need this.
# -----------------------------------------------------------------------------
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [OPTIONAL] Main RAG fallback model — default: llama-3.3-70b-versatile
# Used by groq_client.py when LLM_PROVIDER=groq. Also used by the router node.
GROQ_MODEL=llama-3.3-70b-versatile

# [OPTIONAL] Dedicated RAGAS evaluation model — default: llama-3.1-8b-instant
# Kept separate from GROQ_MODEL so rate limits on one don't affect the other.
# llama-3.1-8b-instant has ~5x higher tokens-per-minute on the Groq free tier.
RAGAS_EVAL_MODEL=llama-3.1-8b-instant

# [OPTIONAL] LLM provider selection — default: gemini
# Set to 'groq' to force Groq as the generation provider (e.g. during outages).
LLM_PROVIDER=gemini

# -----------------------------------------------------------------------------
# Qdrant — Vector database for dense + sparse hybrid search
# URL: your Qdrant instance (local Docker or Qdrant Cloud).
# [REQUIRED] QDRANT_URL — must be reachable at startup.
# -----------------------------------------------------------------------------
QDRANT_URL=https://your-cluster-id.region.gcp.cloud.qdrant.io

# [REQUIRED for Qdrant Cloud] QDRANT_API_KEY — leave blank for local Docker.
QDRANT_API_KEY=

# [OPTIONAL] Collection name — default: documents
QDRANT_COLLECTION_NAME=documents

# [OPTIONAL] Dense vector dimension — default: 768
# Must match GEMINI_EMBEDDING_DIMENSIONS. Rebuild the collection when changing.
QDRANT_VECTOR_SIZE=768

# -----------------------------------------------------------------------------
# Neon PostgreSQL — Conversation memory and document metadata
# Connection string: postgresql://user:password@host/dbname?sslmode=require
# [REQUIRED] DATABASE_URL — without this conversation memory is disabled.
# The asyncpg driver strips ?sslmode=... automatically; SSL is applied via
# connect_args={"ssl": True} instead.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@ep-xxx-xxx.region.aws.neon.tech/dbname?sslmode=require

# -----------------------------------------------------------------------------
# Upstash Redis — Serverless REST-based cache for query results
# Get REST URL and token from https://console.upstash.com/
# [REQUIRED for caching] — if missing, cache is bypassed gracefully (no crash).
# Note: The code reads UPSTASH_REDIS_REST_URL and UPSTASH_REDIS_REST_TOKEN
# (not REDIS_URL / REDIS_TOKEN).
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Langfuse — Observability, tracing, prompt versioning, A/B testing scores
# Get keys at https://cloud.langfuse.com/ (or self-hosted instance).
# [REQUIRED for observability] — if missing, all tracing is silently no-op'd.
# -----------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# [OPTIONAL] Langfuse host — default: https://cloud.langfuse.com
# Override only if running a self-hosted Langfuse instance.
LANGFUSE_HOST=https://cloud.langfuse.com

# -----------------------------------------------------------------------------
# Application — Optional runtime flags
# -----------------------------------------------------------------------------

# [OPTIONAL] Enable debug mode — default: false
# Increases log verbosity. Do NOT enable in production.
APP_DEBUG=false

# -----------------------------------------------------------------------------
# Jina — Cross-encoder reranking API (replaces local PyTorch sentence-transformers)
# Get a free key at https://jina.ai/ (free tier: 1 million tokens / month).
# [REQUIRED for reranking] — if missing, retrieval falls back to hybrid-search
# (RRF) order only. The app still works; reranking quality is just degraded.
# -----------------------------------------------------------------------------
JINA_API_KEY=jina_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [OPTIONAL] Jina reranker model — default: jina-reranker-v2-base-multilingual
# Other option: jina-reranker-v1-base-en (English-only, slightly faster)
JINA_RERANKER_MODEL=jina-reranker-v2-base-multilingual

# -----------------------------------------------------------------------------
# Docker / Cloud Run — Overrides for containerised deployment
# These are NOT needed for local bare-metal development.
# -----------------------------------------------------------------------------

# [DOCKER] Override Qdrant URL to point at the local compose sidecar:
# QDRANT_URL=http://qdrant:6333
# QDRANT_API_KEY=

# [CLOUD RUN] Cloud Run injects PORT automatically; you do not need to set it.
# PORT=8000
